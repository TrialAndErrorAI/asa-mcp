# Apple Search Ads API Credentials
# Get these from https://app.searchads.apple.com → Settings → API → Add API Key

# Client ID (UUID prefixed with SEARCHADS.)
ASA_CLIENT_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Team ID (optional — defaults to ASA_CLIENT_ID if unset)
# ASA_TEAM_ID=SEARCHADS.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Key ID (UUID, no prefix)
ASA_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to your P8 private key file (download once when key is created)
ASA_P8_PATH=/absolute/path/to/apple_search_ads_private_key.p8

# Org ID (numeric — find in Apple Search Ads UI URL or Settings)
ASA_ORG_ID=YOUR_ASA_ORG_ID

# Optional: Non-US org ID (multi-org accounts).
# Note: this is NOT auto-loaded by the server — pass it inline via the
# `execute` tool's `orgId` parameter when targeting the Non-US org.
# ASA_NON_US_ORG_ID=YOUR_NON_US_ORG_ID
