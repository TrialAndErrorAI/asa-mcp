{
  "name": "asa-mcp",
  "version": "0.0.1",
  "description": "Code Mode MCP server for Apple Search Ads — 2 tools, hand-built spec (Apple does not publish OpenAPI for ASA)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/spec && cp src/spec/openapi.json dist/spec/openapi.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:auth": "tsx src/test-auth.ts",
    "test:api": "tsx src/test-api.ts"
  },
  "keywords": [
    "mcp",
    "apple-search-ads",
    "asa",
    "ios",
    "ads",
    "claude"
  ],
  "author": "Trial and Error Inc",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
