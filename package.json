{
  "name": "@trialanderror-ai/asa-mcp",
  "version": "0.1.0",
  "description": "Code Mode MCP server for Apple Search Ads — 2 tools, hand-built spec (Apple does not publish OpenAPI for ASA)",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-apple-search-ads": "dist/index.js"
  },
  "files": [
    "dist/api/**/*.js",
    "dist/api/**/*.d.ts",
    "dist/auth/**/*.js",
    "dist/auth/**/*.d.ts",
    "dist/executor/**/*.js",
    "dist/executor/**/*.d.ts",
    "dist/server/**/*.js",
    "dist/server/**/*.d.ts",
    "dist/spec/**/*.js",
    "dist/spec/**/*.d.ts",
    "dist/spec/openapi.json",
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/spec && cp src/spec/openapi.json dist/spec/openapi.json && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:auth": "tsx test/test-auth.ts",
    "test:api": "tsx test/test-api.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apple-search-ads",
    "apple",
    "ios",
    "code-mode",
    "claude"
  ],
  "author": "Trial and Error Inc",
  "license": "MIT",
  "homepage": "https://github.com/TrialAndErrorAI/asa-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrialAndErrorAI/asa-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/TrialAndErrorAI/asa-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
